# ~/.curlrc — unauffaelligerer Standard fuer curl.
#
# Ein generischer Browser-User-Agent statt "curl/8.x" (das schreit
# "Automat/Bot" und ist ein billiges Fingerprint-Merkmal). Der eigentliche
# Anonymitaets-Teil passiert ohnehin im Egress-Proxy (alles ueber Tor) —
# diese Zeile macht nur die einzelne Anfrage selbst unauffaelliger.
user-agent = "Mozilla/5.0 (X11; Linux x86_64; rv:128.0) Gecko/20100101 Firefox/128.0"
