# Vorlage fuer _docker/.env (NICHT committen — .env steht in .gitignore).
#
# Auf der VPS: cp .env.example .env, dann den echten Hash eintragen.
# docker compose liest .env automatisch (Variablen-Interpolation in
# docker-compose.vps.yml), kein extra --env-file noetig.

# SHA-256-Hash des Passworts fuer die echte Shell (terminal.html
# "real-shell"). NIEMALS das Klartext-Passwort hier eintragen — nur
# den Hash. Berechnen (Linux/Mac):
#   echo -n "DeinPasswort" | sha256sum
# PowerShell:
#   (Get-FileHash -InputStream ([IO.MemoryStream]::new([Text.Encoding]::UTF8.GetBytes("DeinPasswort"))) -Algorithm SHA256).Hash.ToLower()
SHELL_PASSWORD_HASH=
